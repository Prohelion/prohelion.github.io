{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "MkDocs: Serve",
            "type": "node",
            "request": "launch",
            "preLaunchTask": "MkDocs: Serve",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "name": "MkDocs: Build",
            "type": "node",
            "request": "launch",
            "preLaunchTask": "MkDocs: Build",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "name": "Validate Dashboard Examples",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/validate-dashboard-examples.js",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": ["<node_internals>/**"],
            "cwd": "${workspaceFolder}"
        }
    ]
}
